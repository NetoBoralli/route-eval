# Which LLM provider runs the crawl. One of: anthropic | ollama. Default: anthropic.
LLM_PROVIDER=anthropic

# --- Anthropic (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
# Optional model override. Default: claude-sonnet-4-6.
# Use claude-haiku-4-5-20251001 for ~5x cheaper inference.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Ollama (used when LLM_PROVIDER=ollama) ---
# Local model server. Install: https://ollama.com — then `ollama pull qwen2.5:7b`.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# Context window. Default Ollama num_ctx is 2048 which is too small for our
# 30k-char HTML snapshot. 16384 is a safe minimum.
# OLLAMA_NUM_CTX=16384
# Per-request timeout in ms. Default 600000 (10 min) — local models on first
# call do model-load + inference, which trivially exceeds undici's default.
# OLLAMA_TIMEOUT_MS=600000

# --- Debug ---
# Set CRAWL_DEBUG=1 to dump the HTML snapshot, the prompt, and the raw LLM
# response per attempt into ./debug/crawl/ . Useful when discovery fails — you
# can see exactly what the model was shown and what it returned.
# CRAWL_DEBUG=1
# Override the dump directory:
# CRAWL_DEBUG_DIR=debug/crawl
